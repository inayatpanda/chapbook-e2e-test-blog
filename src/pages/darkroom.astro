---
import Base from '../layouts/Base.astro';
import { site } from '../lib/site';
import { withBase } from '../lib/withBase';
import { getDarkroomPhotos } from '../lib/darkroom-build.mjs';
import 'photoswipe/style.css';

const photos = await getDarkroomPhotos();

// Compute the set of facet values actually present, preserving newest-first
// order of first appearance (photos are already date-desc sorted).
const yearSet = new Set<number>();
const topicSet = new Set<string>();
const cameraSet = new Set<string>();
const tagSet = new Set<string>();
const albumSet = new Set<string>();
// Posts: keep slug → title so the chip can show the post title.
const postMap = new Map<string, string>();

for (const p of photos) {
  yearSet.add(p.year);
  for (const t of p.topics) topicSet.add(t);
  if (p.camera) cameraSet.add(p.camera);
  for (const t of p.tags) tagSet.add(t);
  if (p.album) albumSet.add(p.album);
  if (!postMap.has(p.postSlug)) postMap.set(p.postSlug, p.postTitle);
}

const years = [...yearSet].sort((a, b) => b - a);
const topicList = [...topicSet];
const cameras = [...cameraSet];
const tags = [...tagSet];
const albums = [...albumSet];
const posts = [...postMap.entries()].map(([slug, title]) => ({ slug, title }));

// Optional album titles. The file is loaded via a glob so it is genuinely
// optional — if src/data/darkroom-albums.json is absent, the glob is empty and
// every album simply falls back to its title-cased id. Schema:
//   [{ "id": "japan-2026", "title": "Japan, 2026", "description"?: "…" }]
type AlbumDef = { id: string; title?: string; description?: string };
const albumDefsGlob = import.meta.glob<{ default: AlbumDef[] }>(
  '../data/darkroom-albums.json',
  { eager: true },
);
const albumTitles = new Map<string, string>();
for (const mod of Object.values(albumDefsGlob)) {
  const defs = Array.isArray(mod.default) ? mod.default : [];
  for (const def of defs) {
    if (def && def.id && def.title) albumTitles.set(def.id, def.title);
  }
}

// Title-case an album id for use when no explicit title is configured.
const titleCaseId = (id: string) =>
  id
    .split(/[-_]/)
    .filter(Boolean)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');

// Album chip label: the configured title if defined, else the title-cased id.
const albumLabel = (id: string) => albumTitles.get(id) ?? titleCaseId(id);
---
<Base title="Darkroom" description={`A wall of photographs from across the posts on ${site.masthead}.`}>

  <section class="section darkroom-hero">
    <div class="orbs">
      <div class="orb orb-a"></div>
      <div class="orb orb-b"></div>
    </div>
    <div class="grid-lines" aria-hidden="true"></div>
    <div class="container" style="position:relative; z-index:1">
      <p class="eyebrow" data-reveal>Photography</p>
      <h1 class="display scrim-text" data-reveal data-delay="0.07"
          style="font-size:clamp(1.6rem,4vw,2.4rem); margin-top:0.3rem">Darkroom</h1>
      <p class="lead" data-reveal data-delay="0.14" style="margin-top:0.55rem">
        Every photograph from across the posts, collected in one place.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      {photos.length === 0 ? (
        <p style="color: var(--ink-faint); font-family: var(--font-display); font-size:1rem;">
          Nothing developed yet.
        </p>
      ) : (
        <Fragment>
          <div class="darkroom-filter" data-reveal aria-label="Filter photographs">
            {years.length > 1 && (
              <div class="dr-facet" data-facet-group="year">
                <span class="dr-facet-label">Year</span>
                {years.map((y) => (
                  <button type="button" class="chip" data-facet="year" data-value={String(y)}>{y}</button>
                ))}
              </div>
            )}
            {topicList.length > 1 && (
              <div class="dr-facet" data-facet-group="topic">
                <span class="dr-facet-label">Topic</span>
                {topicList.map((t) => (
                  <button type="button" class="chip" data-facet="topic" data-value={t}>{t}</button>
                ))}
              </div>
            )}
            {cameras.length > 1 && (
              <div class="dr-facet" data-facet-group="camera">
                <span class="dr-facet-label">Camera</span>
                {cameras.map((c) => (
                  <button type="button" class="chip" data-facet="camera" data-value={c}>{c}</button>
                ))}
              </div>
            )}
            {tags.length > 0 && (
              <div class="dr-facet" data-facet-group="tag">
                <span class="dr-facet-label">Tags</span>
                {tags.map((t) => (
                  <button type="button" class="chip" data-facet="tag" data-value={t}>{t}</button>
                ))}
              </div>
            )}
            {albums.length > 0 && (
              <div class="dr-facet" data-facet-group="album">
                <span class="dr-facet-label">Album</span>
                {albums.map((a) => (
                  <button type="button" class="chip" data-facet="album" data-value={a}>{albumLabel(a)}</button>
                ))}
              </div>
            )}
            {posts.length > 1 && (
              <div class="dr-facet" data-facet-group="post">
                <span class="dr-facet-label">Post</span>
                {posts.map((p) => (
                  <button type="button" class="chip" data-facet="post" data-value={p.slug}>{p.title}</button>
                ))}
              </div>
            )}
            <div class="dr-facet dr-facet-meta">
              <span id="dr-count" class="dr-count">{photos.length} photos</span>
              <button type="button" id="dr-clear" class="chip">Clear</button>
            </div>
          </div>

          <div id="darkroom-grid" class="darkroom-grid" data-blogbase={withBase('/blog/')}>
            {photos.map((photo) => (
              <a class="dr-shot"
                 href={photo.full}
                 data-pswp-width={photo.width}
                 data-pswp-height={photo.height}
                 data-year={photo.year}
                 data-topics={photo.topics.join(' ')}
                 data-camera={photo.camera ?? ''}
                 data-tags={photo.tags.join(' ')}
                 data-album={photo.album ?? ''}
                 data-post={photo.postSlug}
                 data-caption={photo.caption ?? ''}
                 data-posttitle={photo.postTitle}
                 data-postslug={photo.postSlug}>
                <img src={photo.thumb}
                     loading="lazy"
                     decoding="async"
                     alt={photo.caption ?? ''}
                     width={500}
                     height={Math.round((500 * photo.height) / photo.width)} />
              </a>
            ))}
          </div>
        </Fragment>
      )}
    </div>
  </section>

  <script>
    import '../scripts/darkroom.js';
  </script>

</Base>
