---
// Animated medical vector: navigated glenoid baseplate, en-face scapula.
// Line-draw on scroll into view, rotating targeting reticle, pulsing data nodes.
// High-contrast strokes with glow — meant to be SEEN.
---
<svg
  class="glenoid-art"
  data-draw
  viewBox="0 0 520 460"
  role="img"
  aria-label="Animated diagram of a navigated glenoid baseplate with targeting reticle"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <filter id="ga-glow" x="-40%" y="-40%" width="180%" height="180%">
      <feGaussianBlur stdDeviation="3.2" result="b" />
      <feMerge>
        <feMergeNode in="b" /><feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
    <linearGradient id="ga-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#2dd4bf" />
      <stop offset="0.5" stop-color="#22d3ee" />
      <stop offset="1" stop-color="#818cf8" />
    </linearGradient>
  </defs>

  <!-- scapula en-face outline (drawn) -->
  <path
    class="draw d1"
    d="M150 52
       C 110 78, 84 130, 86 188
       C 88 246, 112 304, 158 350
       C 186 378, 224 400, 262 404
       C 252 360, 248 312, 252 266
       C 256 214, 270 164, 296 122
       C 270 96, 234 72, 196 58
       C 180 52, 164 50, 150 52 Z"
    fill="none" stroke="url(#ga-grad)" stroke-width="2.4" filter="url(#ga-glow)"
  />
  <!-- glenoid fossa (drawn) -->
  <ellipse
    class="draw d2"
    cx="318" cy="218" rx="58" ry="86"
    fill="none" stroke="#22d3ee" stroke-width="2.6" filter="url(#ga-glow)"
  />
  <!-- baseplate disc + central peg -->
  <g class="fade f1" filter="url(#ga-glow)">
    <ellipse cx="318" cy="218" rx="34" ry="50" fill="rgba(34,211,238,0.08)" stroke="#2dd4bf" stroke-width="2.2" />
    <line x1="318" y1="218" x2="252" y2="252" stroke="#2dd4bf" stroke-width="2.4" />
    <circle cx="318" cy="218" r="5" fill="#2dd4bf" />
  </g>
  <!-- baseplate screws (drawn) -->
  <g class="draw d3" stroke="#818cf8" stroke-width="2" fill="none" filter="url(#ga-glow)">
    <line x1="318" y1="172" x2="318" y2="142" />
    <line x1="318" y1="264" x2="318" y2="294" />
    <line x1="288" y1="200" x2="262" y2="186" />
    <line x1="348" y1="236" x2="374" y2="250" />
  </g>

  <!-- targeting reticle: rotates continuously -->
  <g class="reticle" filter="url(#ga-glow)">
    <circle cx="318" cy="218" r="108" fill="none" stroke="#22d3ee" stroke-width="1.2" stroke-dasharray="10 14" opacity="0.85" />
    <circle cx="318" cy="218" r="128" fill="none" stroke="#818cf8" stroke-width="0.9" stroke-dasharray="3 18" opacity="0.6" />
    <line x1="318" y1="84" x2="318" y2="106" stroke="#22d3ee" stroke-width="2" />
    <line x1="318" y1="330" x2="318" y2="352" stroke="#22d3ee" stroke-width="2" />
    <line x1="184" y1="218" x2="206" y2="218" stroke="#22d3ee" stroke-width="2" />
    <line x1="430" y1="218" x2="452" y2="218" stroke="#22d3ee" stroke-width="2" />
  </g>

  <!-- data nodes + leader lines -->
  <g class="fade f2" font-family="Space Grotesk Variable, Space Grotesk, sans-serif" font-size="11" letter-spacing="0.08em">
    <g filter="url(#ga-glow)">
      <circle class="node n1" cx="376" cy="148" r="5" fill="#2dd4bf" />
      <line x1="381" y1="143" x2="430" y2="108" stroke="#2dd4bf" stroke-width="1" opacity="0.7" />
    </g>
    <text x="436" y="104" fill="#b3bdd1">VERSION 2.1°</text>

    <g filter="url(#ga-glow)">
      <circle class="node n2" cx="370" cy="290" r="5" fill="#818cf8" />
      <line x1="375" y1="295" x2="424" y2="330" stroke="#818cf8" stroke-width="1" opacity="0.7" />
    </g>
    <text x="430" y="344" fill="#b3bdd1">INCLINATION 0.8°</text>

    <g filter="url(#ga-glow)">
      <circle class="node n3" cx="252" cy="252" r="5" fill="#22d3ee" />
      <line x1="246" y1="257" x2="196" y2="296" stroke="#22d3ee" stroke-width="1" opacity="0.7" />
    </g>
    <text x="96" y="312" fill="#b3bdd1">SEATING 100%</text>
  </g>
</svg>

<style>
  .glenoid-art {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* Theme-aware: remap the base teal/cyan/violet to the active site theme's accent
     vars (CSS overrides the SVG presentation attributes). Default theme = same hexes. */
  .glenoid-art [stroke="#2dd4bf"] { stroke: var(--teal); }
  .glenoid-art [stroke="#22d3ee"] { stroke: var(--cyan); }
  .glenoid-art [stroke="#818cf8"] { stroke: var(--violet); }
  .glenoid-art [fill="#2dd4bf"] { fill: var(--teal); }
  .glenoid-art [fill="#22d3ee"] { fill: var(--cyan); }
  .glenoid-art [fill="#818cf8"] { fill: var(--violet); }
  .glenoid-art [stop-color="#2dd4bf"] { stop-color: var(--teal); }
  .glenoid-art [stop-color="#22d3ee"] { stop-color: var(--cyan); }
  .glenoid-art [stop-color="#818cf8"] { stop-color: var(--violet); }
  .glenoid-art [fill="rgba(34,211,238,0.08)"] { fill: rgba(255, 255, 255, 0.05); }

  /* line draw */
  .glenoid-art .draw {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
  }
  .glenoid-art.is-inview .draw {
    animation: ga-draw 1.8s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }
  .glenoid-art.is-inview .d2 { animation-delay: 0.5s; }
  .glenoid-art.is-inview .d3 { animation-delay: 1.1s; }
  @keyframes ga-draw { to { stroke-dashoffset: 0; } }

  /* fades */
  .glenoid-art .fade { opacity: 0; }
  .glenoid-art.is-inview .fade { animation: ga-fade 0.9s ease forwards; }
  .glenoid-art.is-inview .f1 { animation-delay: 1.3s; }
  .glenoid-art.is-inview .f2 { animation-delay: 1.7s; }
  @keyframes ga-fade { to { opacity: 1; } }

  /* rotating reticle */
  .glenoid-art .reticle {
    transform-origin: 318px 218px;
    opacity: 0;
  }
  .glenoid-art.is-inview .reticle {
    opacity: 1;
    transition: opacity 1s ease 0.9s;
    animation: ga-spin 26s linear infinite;
  }
  @keyframes ga-spin { to { transform: rotate(360deg); } }

  /* pulsing nodes */
  .glenoid-art .node { animation: ga-pulse 2.4s ease-in-out infinite; }
  .glenoid-art .n2 { animation-delay: 0.8s; }
  .glenoid-art .n3 { animation-delay: 1.6s; }
  @keyframes ga-pulse { 50% { opacity: 0.35; r: 7; } }

  @media (prefers-reduced-motion: reduce) {
    .glenoid-art .draw { stroke-dashoffset: 0; animation: none; }
    .glenoid-art .fade, .glenoid-art .reticle { opacity: 1; animation: none; transition: none; }
    .glenoid-art .node { animation: none; }
  }
</style>
