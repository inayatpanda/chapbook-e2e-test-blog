---
// Icon.astro — render a Tabler line icon inline, themeable via currentColor.
// Usage: <Icon name="stethoscope" size={28} /> or <Icon name="building-monument" class="glow" />
import { iconInner } from '../lib/icons.js';
const { name, size = 24, stroke = 2, class: cls = '', label } = Astro.props;
const inner = iconInner(name);
---
{inner && (
  <svg
    class:list={['icon', cls]}
    width={size} height={size} viewBox="0 0 24 24"
    fill="none" stroke="currentColor" stroke-width={stroke}
    stroke-linecap="round" stroke-linejoin="round"
    role={label ? 'img' : undefined}
    aria-label={label || undefined}
    aria-hidden={label ? undefined : 'true'}
    set:html={inner}
  />
)}
